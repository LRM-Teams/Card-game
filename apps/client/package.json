{
  "name": "@card-game/client",
  "version": "0.0.1",
  "private": true,
  "description": "斗地主前端：React + Vite（牌桌 / 手牌 UI、选牌出牌交互、实时状态展示）",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "fx:record": "playwright test e2e/lrm168-fx.spec.ts"
  },
  "dependencies": {
    "@card-game/rules": "workspace:*",
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify/react": "^6.0.2",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-router": "^1.81.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.0"
  }
}
